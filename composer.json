{
    "name": "confluxapi/magento2-payment",
    "description": "Conflux payment integration for Magento 2.",
    "type": "magento2-module",
    "license": "MIT",
    "keywords": [
        "magento2",
        "magento2-module",
        "payment",
        "checkout",
        "conflux"
    ],
    "homepage": "https://github.com/ideal-source/confluxapi-magento2-payment",
    "support": {
        "issues": "https://github.com/ideal-source/confluxapi-magento2-payment/issues",
        "source": "https://github.com/ideal-source/confluxapi-magento2-payment"
    },
    "require": {
        "php": "^8.1",
        "magento/framework": "^103.0",
        "magento/module-checkout": "^100.4",
        "magento/module-config": "^101.2",
        "magento/module-directory": "^100.4",
        "magento/module-payment": "^100.4",
        "magento/module-sales": "^103.0",
        "magento/module-store": "^101.1"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    },
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "Conflux\\Payment\\": ""
        }
    }
}
