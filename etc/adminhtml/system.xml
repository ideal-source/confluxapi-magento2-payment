<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <section id="payment">
            <group id="conflux_direct" translate="label" type="text" sortOrder="900" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Conflux Credit Card</label>
                <field id="active" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" canRestore="1">
                    <label>Enabled</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="title" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Title</label>
                </field>
                <field id="order_status" translate="label" type="select" sortOrder="30" showInDefault="1" showInWebsite="1" canRestore="1">
                    <label>New Order Status</label>
                    <source_model>Magento\Sales\Model\Config\Source\Order\Status\NewStatus</source_model>
                </field>
                <field id="environment" translate="label comment" type="text" sortOrder="40" showInDefault="1" showInWebsite="1">
                    <label>API Base URL</label>
                    <comment>Enter the full Conflux API base URL, including https://</comment>
                    <validate>validate-url</validate>
                </field>
                <field id="app_id" translate="label" type="text" sortOrder="50" showInDefault="1" showInWebsite="1">
                    <label>App ID</label>
                </field>
                <field id="app_secret" translate="label" type="obscure" sortOrder="60" showInDefault="1" showInWebsite="1">
                    <label>App Secret</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                </field>
                <field id="mch_no" translate="label" type="text" sortOrder="70" showInDefault="1" showInWebsite="1">
                    <label>Merchant Number</label>
                </field>
                <field id="gateway_no" translate="label" type="text" sortOrder="80" showInDefault="1" showInWebsite="1">
                    <label>Gateway Number</label>
                </field>
                <field id="allowspecific" translate="label" type="allowspecific" sortOrder="110" showInDefault="1" showInWebsite="1" canRestore="1">
                    <label>Payment from Applicable Countries</label>
                    <source_model>Magento\Payment\Model\Config\Source\Allspecificcountries</source_model>
                </field>
                <field id="specificcountry" translate="label" type="multiselect" sortOrder="120" showInDefault="1" showInWebsite="1">
                    <label>Payment from Specific Countries</label>
                    <source_model>Magento\Directory\Model\Config\Source\Country</source_model>
                    <can_be_empty>1</can_be_empty>
                </field>
                <field id="min_order_total" translate="label" type="text" sortOrder="130" showInDefault="1" showInWebsite="1">
                    <label>Minimum Order Total</label>
                    <validate>validate-number validate-zero-or-greater</validate>
                </field>
                <field id="max_order_total" translate="label" type="text" sortOrder="140" showInDefault="1" showInWebsite="1">
                    <label>Maximum Order Total</label>
                    <validate>validate-number validate-zero-or-greater</validate>
                </field>
                <field id="sort_order" translate="label" type="text" sortOrder="150" showInDefault="1" showInWebsite="1">
                    <label>Sort Order</label>
                    <validate>validate-number</validate>
                </field>
            </group>
            <group id="conflux_checkout" translate="label" type="text" sortOrder="901" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Conflux Hosted Checkout</label>
                <field id="active" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" canRestore="1">
                    <label>Enabled</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="title" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Title</label>
                </field>
                <field id="order_status" translate="label" type="select" sortOrder="30" showInDefault="1" showInWebsite="1" canRestore="1">
                    <label>New Order Status</label>
                    <source_model>Magento\Sales\Model\Config\Source\Order\Status\NewStatus</source_model>
                </field>
                <field id="environment" translate="label comment" type="text" sortOrder="40" showInDefault="1" showInWebsite="1">
                    <label>API Base URL</label>
                    <comment>Enter the full Conflux API base URL, including https://</comment>
                    <validate>validate-url</validate>
                </field>
                <field id="app_id" translate="label" type="text" sortOrder="50" showInDefault="1" showInWebsite="1">
                    <label>App ID</label>
                </field>
                <field id="app_secret" translate="label" type="obscure" sortOrder="60" showInDefault="1" showInWebsite="1">
                    <label>App Secret</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                </field>
                <field id="mch_no" translate="label" type="text" sortOrder="70" showInDefault="1" showInWebsite="1">
                    <label>Merchant Number</label>
                </field>
                <field id="gateway_no" translate="label" type="text" sortOrder="80" showInDefault="1" showInWebsite="1">
                    <label>Gateway Number</label>
                </field>
                <field id="expires_in" translate="label" type="text" sortOrder="90" showInDefault="1" showInWebsite="1">
                    <label>Checkout Expires In Seconds</label>
                    <validate>validate-number validate-zero-or-greater</validate>
                </field>
                <field id="allowspecific" translate="label" type="allowspecific" sortOrder="120" showInDefault="1" showInWebsite="1" canRestore="1">
                    <label>Payment from Applicable Countries</label>
                    <source_model>Magento\Payment\Model\Config\Source\Allspecificcountries</source_model>
                </field>
                <field id="specificcountry" translate="label" type="multiselect" sortOrder="130" showInDefault="1" showInWebsite="1">
                    <label>Payment from Specific Countries</label>
                    <source_model>Magento\Directory\Model\Config\Source\Country</source_model>
                    <can_be_empty>1</can_be_empty>
                </field>
                <field id="min_order_total" translate="label" type="text" sortOrder="140" showInDefault="1" showInWebsite="1">
                    <label>Minimum Order Total</label>
                    <validate>validate-number validate-zero-or-greater</validate>
                </field>
                <field id="max_order_total" translate="label" type="text" sortOrder="150" showInDefault="1" showInWebsite="1">
                    <label>Maximum Order Total</label>
                    <validate>validate-number validate-zero-or-greater</validate>
                </field>
                <field id="sort_order" translate="label" type="text" sortOrder="160" showInDefault="1" showInWebsite="1">
                    <label>Sort Order</label>
                    <validate>validate-number</validate>
                </field>
            </group>
        </section>
    </system>
</config>
